---
layout: default
---
<style>
  .edu-exp-page {
    --edu-exp-border: color-mix(in srgb, var(--global-divider-color) 82%, transparent);
    --edu-exp-soft: color-mix(in srgb, var(--global-theme-color) 8%, transparent);
    --edu-exp-soft-strong: color-mix(in srgb, var(--global-theme-color) 14%, transparent);
    --edu-exp-muted: var(--global-text-color-light);
  }

  .edu-exp-page .post-header {
    margin-bottom: 2.5rem;
    max-width: 42rem;
  }

  .edu-exp-intro {
    color: var(--edu-exp-muted);
    line-height: 1.75;
    margin-bottom: 0;
  }

  .edu-exp-section + .edu-exp-section {
    margin-top: 3.5rem;
  }

  .edu-exp-section-title {
    align-items: end;
    border-bottom: 1px solid var(--edu-exp-border);
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    margin-bottom: 1.75rem;
    padding-bottom: 0.85rem;
  }

  .edu-exp-section-title h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  .edu-exp-section-title p {
    color: var(--edu-exp-muted);
    font-size: 0.95rem;
    margin: 0;
    max-width: 32rem;
    text-align: right;
  }

  .edu-exp-list {
    display: grid;
    gap: 1.5rem;
  }

  .edu-exp-item {
    column-gap: 1.25rem;
    display: grid;
    grid-template-columns: minmax(8.5rem, 10rem) 4.5rem minmax(0, 1fr);
    position: relative;
  }

  .edu-exp-date {
    color: var(--edu-exp-muted);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding-top: 0.8rem;
  }

  .edu-exp-marker {
    align-items: flex-start;
    display: flex;
    justify-content: center;
    position: relative;
  }

  .edu-exp-marker::before {
    background: var(--edu-exp-border);
    bottom: -1.5rem;
    content: "";
    left: 50%;
    position: absolute;
    top: -1.5rem;
    transform: translateX(-50%);
    width: 1px;
  }

  .edu-exp-item:first-child .edu-exp-marker::before {
    top: 2.25rem;
  }

  .edu-exp-item:last-child .edu-exp-marker::before {
    bottom: 2.25rem;
  }

  .edu-exp-badge {
    align-items: center;
    background: linear-gradient(145deg, var(--edu-exp-soft) 0%, var(--global-card-bg-color) 100%);
    border: 1px solid var(--edu-exp-border);
    border-radius: 1rem;
    box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    display: flex;
    height: 3.6rem;
    justify-content: center;
    overflow: hidden;
    position: relative;
    width: 3.6rem;
    z-index: 1;
  }

  .edu-exp-badge img {
    height: 100%;
    object-fit: contain;
    padding: 0.55rem;
    width: 100%;
  }

  .edu-exp-badge span {
    color: var(--global-theme-color);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .edu-exp-content {
    background: linear-gradient(180deg, var(--edu-exp-soft) 0%, transparent 100%);
    border: 1px solid var(--edu-exp-border);
    border-radius: 1.15rem;
    padding: 1rem 1.15rem 1rem 1.2rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .edu-exp-item:hover .edu-exp-content {
    border-color: color-mix(in srgb, var(--global-theme-color) 28%, var(--edu-exp-border));
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
    transform: translateY(-1px);
  }

  .edu-exp-role {
    font-size: 1.08rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .edu-exp-org {
    color: var(--global-text-color);
    font-size: 0.98rem;
    line-height: 1.55;
    margin: 0.3rem 0 0;
  }

  .edu-exp-meta {
    color: var(--edu-exp-muted);
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0.45rem 0 0;
  }

  .edu-exp-notes {
    margin: 0.7rem 0 0;
    padding-left: 1.05rem;
  }

  .edu-exp-notes li {
    line-height: 1.65;
    margin-bottom: 0.2rem;
  }

  @media (max-width: 768px) {
    .edu-exp-section-title {
      align-items: start;
      flex-direction: column;
      gap: 0.35rem;
    }

    .edu-exp-section-title p {
      max-width: none;
      text-align: left;
    }

    .edu-exp-item {
      column-gap: 0.9rem;
      grid-template-columns: 1fr 3.6rem;
      grid-template-rows: auto auto;
    }

    .edu-exp-date {
      grid-column: 1 / -1;
      padding-top: 0;
    }

    .edu-exp-marker {
      grid-column: 1;
      grid-row: 2;
      justify-content: flex-start;
    }

    .edu-exp-marker::before {
      left: 1.8rem;
      transform: none;
    }

    .edu-exp-content {
      grid-column: 2;
      grid-row: 2;
      padding: 0.95rem 1rem;
    }
  }

  @media (max-width: 520px) {
    .edu-exp-item {
      gap: 0.8rem;
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .edu-exp-marker {
      grid-column: 1;
      grid-row: 2;
    }

    .edu-exp-marker::before {
      display: none;
    }

    .edu-exp-content {
      grid-column: 1;
      grid-row: 3;
    }
  }
</style>

<div class="post edu-exp-page">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
    {% if page.intro %}
      <p class="edu-exp-intro">{{ page.intro }}</p>
    {% endif %}
  </header>

  <article>
    {% assign sections = site.data['edu-and-exp'] %}
    {% for section in sections %}
      <section class="edu-exp-section" id="{{ section.title | slugify }}">
        <div class="edu-exp-section-title">
          <h2>{{ section.title }}</h2>
          {% if section.summary %}
            <p>{{ section.summary }}</p>
          {% endif %}
        </div>

        <div class="edu-exp-list">
          {% for item in section.contents %}
            <article class="edu-exp-item">
              <div class="edu-exp-date">{{ item.year }}</div>

              <div class="edu-exp-marker">
                <div class="edu-exp-badge" aria-hidden="true">
                  {% if item.logo %}
                    <img src="{{ item.logo | relative_url }}" alt="{{ item.title | strip_html }}">
                  {% else %}
                    <span>{{ item.badge | default: item.title | slice: 0, 3 }}</span>
                  {% endif %}
                </div>
              </div>

              <div class="edu-exp-content">
                <h3 class="edu-exp-role">{{ item.title }}</h3>
                <p class="edu-exp-org">{{ item.institution }}</p>
                {% if item.meta %}
                  <p class="edu-exp-meta">{{ item.meta }}</p>
                {% endif %}
                {% if item.description %}
                  <ul class="edu-exp-notes">
                    {% for note in item.description %}
                      <li>{{ note }}</li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </article>
</div>
