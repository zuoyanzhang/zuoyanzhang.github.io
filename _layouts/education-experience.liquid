---
layout: default
---
<style>
  .edu-exp-page {
    --edu-exp-border: color-mix(in srgb, var(--global-divider-color) 72%, transparent);
    --edu-exp-muted: var(--global-text-color-light);
    --edu-exp-date-color: color-mix(in srgb, var(--global-text-color) 70%, var(--global-bg-color));
  }

  .edu-exp-page .post-header {
    margin-bottom: 1.7rem;
  }

  .edu-exp-section + .edu-exp-section {
    margin-top: 3.2rem;
  }

  .edu-exp-section-title {
    border-bottom: 1px solid var(--edu-exp-border);
    margin-bottom: 1.5rem;
    padding-bottom: 0.8rem;
  }

  .edu-exp-section-title h2 {
    font-size: 1.5rem;
    margin: 0;
  }

  .edu-exp-list {
    display: grid;
    gap: 0.95rem;
  }

  .edu-exp-item {
    column-gap: 1.25rem;
    display: grid;
    grid-template-columns: minmax(8.3rem, 9.6rem) 5rem minmax(0, 1fr);
    position: relative;
  }

  .edu-exp-date {
    color: var(--edu-exp-date-color);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1.5;
    padding-top: 0.55rem;
  }

  .edu-exp-marker {
    align-items: flex-start;
    display: flex;
    justify-content: center;
    position: relative;
  }

  .edu-exp-marker::before {
    background: var(--edu-exp-border);
    bottom: -1.5rem;
    content: "";
    left: 50%;
    position: absolute;
    top: -1.5rem;
    transform: translateX(-50%);
    width: 1px;
  }

  .edu-exp-item:first-child .edu-exp-marker::before {
    top: 2.25rem;
  }

  .edu-exp-item:last-child .edu-exp-marker::before {
    bottom: 2.25rem;
  }

  .edu-exp-badge {
    align-items: center;
    display: flex;
    height: 4.9rem;
    justify-content: center;
    overflow: hidden;
    position: relative;
    width: 4.9rem;
    z-index: 1;
  }

  .edu-exp-badge img {
    height: 100%;
    filter: saturate(0.97) contrast(1.03);
    object-fit: contain;
    width: 100%;
  }

  .edu-exp-badge span {
    color: var(--global-theme-color);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .edu-exp-content {
    position: relative;
    padding: 0.35rem 0 0.95rem;
  }

  .edu-exp-item:not(:last-child) .edu-exp-content::after {
    background: var(--edu-exp-border);
    bottom: 0;
    content: "";
    height: 1px;
    left: 0;
    position: absolute;
    width: 88%;
  }

  .edu-exp-role {
    font-size: 1.06rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0;
  }

  .edu-exp-org {
    color: var(--global-text-color);
    font-size: 0.96rem;
    line-height: 1.5;
    margin: 0.2rem 0 0;
  }

  .edu-exp-suborg {
    color: var(--edu-exp-date-color);
    font-size: 0.88rem;
    line-height: 1.55;
    margin: 0.2rem 0 0;
  }

  .edu-exp-notes {
    margin: 0.55rem 0 0;
    padding-left: 1rem;
  }

  .edu-exp-notes li {
    line-height: 1.55;
    margin-bottom: 0.16rem;
  }

  @media (max-width: 768px) {
    .edu-exp-item {
      column-gap: 0.9rem;
      grid-template-columns: 1fr 4.9rem;
      grid-template-rows: auto auto;
    }

    .edu-exp-date {
      grid-column: 1 / -1;
      padding-top: 0;
    }

    .edu-exp-marker {
      grid-column: 1;
      grid-row: 2;
      justify-content: flex-start;
    }

    .edu-exp-marker::before {
      left: 2.45rem;
      transform: none;
    }

    .edu-exp-content {
      grid-column: 2;
      grid-row: 2;
      padding: 0.25rem 0 0.85rem;
    }

    .edu-exp-item:not(:last-child) .edu-exp-content::after {
      width: 92%;
    }
  }

  @media (max-width: 520px) {
    .edu-exp-item {
      gap: 0.8rem;
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .edu-exp-marker {
      grid-column: 1;
      grid-row: 2;
    }

    .edu-exp-marker::before {
      display: none;
    }

    .edu-exp-content {
      grid-column: 1;
      grid-row: 3;
    }
  }
</style>

<div class="post edu-exp-page">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
  </header>

  <article>
    {% assign sections = site.data['edu-and-exp'] %}
    {% for section in sections %}
      <section class="edu-exp-section" id="{{ section.title | slugify }}">
        <div class="edu-exp-section-title">
          <h2>{{ section.title }}</h2>
        </div>

        <div class="edu-exp-list">
          {% for item in section.contents %}
            <article class="edu-exp-item">
              <div class="edu-exp-date">{{ item.year }}</div>

              <div class="edu-exp-marker">
                <div class="edu-exp-badge" aria-hidden="true">
                  {% if item.logo %}
                    <img src="{{ item.logo | relative_url }}" alt="{{ item.title | strip_html }}">
                  {% else %}
                    <span>{{ item.badge | default: item.title | slice: 0, 3 }}</span>
                  {% endif %}
                </div>
              </div>

              <div class="edu-exp-content">
                <h3 class="edu-exp-role">{{ item.title }}</h3>
                <p class="edu-exp-org">{{ item.institution }}</p>
                {% if item.subinstitution %}
                  <p class="edu-exp-suborg">{{ item.subinstitution }}</p>
                {% endif %}
                {% if item.description %}
                  <ul class="edu-exp-notes">
                    {% for note in item.description %}
                      <li>{{ note }}</li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </article>
</div>
